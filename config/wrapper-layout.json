{
  "layoutVersion": 1,
  "targetRepo": "axolync-platform-wrapper",
  "compatibilityMode": false,
  "wrappersRoot": "wrappers",
  "nativeServiceCompanions": {
    "hostProtocol": "native-service-companions/host-protocol",
    "deployment": "native-service-companions/deployment",
    "diagnostics": "native-service-companions/diagnostics"
  },
  "families": {
    "capacitor": {
      "root": "wrappers/mobile/capacitor",
      "android": {
        "authorityPath": "wrappers/mobile/capacitor/android",
        "projectRoot": "wrappers/mobile/capacitor/android",
        "gradleProjectPath": "wrappers/mobile/capacitor/android/app",
        "assetPublicPath": "wrappers/mobile/capacitor/android/app/src/main/assets/public",
        "nativeSourcePath": "wrappers/mobile/capacitor/android/app/src/main/kotlin/com/axolync/android",
        "legacyCompatibilityProjectRoot": ".",
        "legacyCompatibilityMode": "root-shim",
        "legacyShimPaths": [
          "app",
          "build.gradle.kts",
          "settings.gradle.kts",
          "capacitor.config.json",
          "gradle",
          "gradlew",
          "gradlew.bat"
        ]
      },
      "shared": {
        "authorityPath": "wrappers/mobile/capacitor/shared"
      },
      "ios": {
        "authorityPath": "wrappers/mobile/capacitor/ios",
        "support": "placeholder-only"
      }
    },
    "tauri": {
      "root": "wrappers/desktop/tauri/workspace-template",
      "desktop": {
        "authorityPath": "wrappers/desktop/tauri/workspace-template",
        "templateRoot": "wrappers/desktop/tauri/workspace-template",
        "nativeServiceCompanionHost": "wrappers/desktop/tauri/workspace-template/src-tauri/src/native_service_companion.rs"
      }
    },
    "electron": {
      "root": "wrappers/desktop/electron/workspace-template",
      "desktop": {
        "authorityPath": "wrappers/desktop/electron/workspace-template",
        "templateRoot": "wrappers/desktop/electron/workspace-template",
        "nativeServiceCompanionHost": "wrappers/desktop/electron/workspace-template/nativeServiceCompanionHost.cjs"
      }
    }
  }
}
